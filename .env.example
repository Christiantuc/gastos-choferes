# Copie a .env en su PC (no subir .env a GitHub)
ADMIN_PASSWORD=cambiar-clave-admin
MASTER_PASSWORD=cambiar-clave-master
SECRET_KEY=una-clave-secreta-larga-y-aleatoria
FLASK_DEBUG=false

# --- Almacenamiento permanente de fotos (Render / internet) ---
# Sin estas variables las fotos se guardan solo en data/uploads/ (se pierden al redeploy).
# Guía paso a paso: ALMACENAMIENTO-FOTOS.md
#
# STORAGE_BACKEND=s3
# S3_BUCKET=gastos-fotos-choferes
# S3_ACCESS_KEY_ID=tu-access-key
# S3_SECRET_ACCESS_KEY=tu-secret-key
# S3_ENDPOINT_URL=https://TU_ACCOUNT_ID.r2.cloudflarestorage.com
# S3_REGION=auto
